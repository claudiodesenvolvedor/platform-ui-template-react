# ========================================
# APP CONFIG
# ========================================
VITE_APP_NAME=[Nome do Sistema]
VITE_APP_VERSION=1.0.0

# ========================================
# API CONFIG
# ========================================
VITE_API_URL=https://localhost:5001/api
VITE_API_TIMEOUT=5000

# ========================================
# AUTH CONFIG
# ========================================
VITE_DEV_ROLE=admin
# Producao: manter obrigatoriamente em false
VITE_ENABLE_AUTH_FALLBACK=true

# ========================================
# FEATURE FLAGS (DEFAULT)
# ========================================
VITE_FEATURE_USERS=true
VITE_FEATURE_REPORTS=true
VITE_FEATURE_AUDIT=false